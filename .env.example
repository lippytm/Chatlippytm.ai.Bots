# AI Engine Configuration
# Copy this file to .env and fill in your values

# OpenAI API credentials
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_here          # optional

# GitHub credentials for swarm repo scanning
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=lippytm

# Swarm settings
SWARM_MAX_AGENTS=10
SWARM_CONCURRENCY=4
SWARM_TASK_TIMEOUT=300

# Training settings
TRAINING_MODEL=gpt-4o
TRAINING_TEMPERATURE=0.2
TRAINING_MAX_TOKENS=4096
AUTO_TRAIN_ON_PUSH=true

# Agent settings
AGENT_MODEL=gpt-4o
AGENT_VERBOSE=false
AGENT_MAX_ITERATIONS=15

# ---------------------------------------------------------------------------
# Web3 Workshop Platform
# ---------------------------------------------------------------------------

# Server-side secret for HMAC challenge/session tokens (use a long random value)
WEB3_SECRET_KEY=change_me_to_a_long_random_secret

# Wallet session lifetime in seconds (default 3600 = 1 hour)
WEB3_SESSION_TTL=3600

# Sign-in challenge validity window in seconds (default 300 = 5 min)
WEB3_CHALLENGE_TTL=300

# Sandbox resource limits per participant environment
SANDBOX_CPU_LIMIT=1.0
SANDBOX_MEMORY_MB=512
